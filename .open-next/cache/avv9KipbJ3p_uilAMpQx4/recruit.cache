t-slate-600 hover:text-brand-blue\" href=\"/about\">About</a><a class=\"relative px-3 py-2 text-sm font-semibold rounded-lg transition-colors duration-200\n                    text-slate-600 hover:text-brand-blue\" href=\"/squad\">Squad</a><a class=\"relative px-3 py-2 text-sm font-semibold rounded-lg transition-colors duration-200\n                    text-slate-600 hover:text-brand-blue\" href=\"/coach\">Coach</a><a class=\"relative px-3 py-2 text-sm font-semibold rounded-lg transition-colors duration-200\n                    text-slate-600 hover:text-brand-blue\" href=\"/matches\">Matches</a><a class=\"relative px-3 py-2 text-sm font-semibold rounded-lg transition-colors duration-200\n                    text-slate-600 hover:text-brand-blue\" href=\"/gallery\">Gallery</a><a class=\"relative px-3 py-2 text-sm font-semibold rounded-lg transition-colors duration-200\n                    text-slate-600 hover:text-brand-blue\" href=\"/virtual-pitch\">Pitch</a><a class=\"btn-blue ml-2 text-xs !px-4 !py-2 shadow-none\" href=\"/recruit\">Join Us</a></nav><button id=\"mobile-menu-btn\" aria-label=\"Toggle navigation\" class=\"md:hidden w-9 h-9 rounded-lg flex items-center justify-center transition-colors\n              bg-slate-100 text-slate-700 hover:bg-slate-200\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu w-4 h-4\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></header><main class=\"min-h-screen pt-16\"><div style=\"opacity:1;transform:none\"><!--$--><div><section class=\"relative h-64 flex items-end overflow-hidden bg-white border-b border-slate-200\"><div class=\"absolute inset-0 bg-gradient-to-br from-blue-50/50 via-white to-slate-50\"></div><div class=\"absolute inset-0 opacity-[0.03]\" style=\"background-image:radial-gradient(#003087 1px, transparent 1px);background-size:24px 24px\"></div><div class=\"relative z-10 max-w-7xl mx-auto px-4 md:px-8 w-full pb-10\"><div style=\"opacity:1;transform:none\"><p class=\"label-sm mb-2 text-brand-blue\">Season 2026/27</p><h1 class=\"heading-section text-4xl md:text-5xl text-slate-900\">Join the Team</h1></div></div></section><section class=\"max-w-6xl mx-auto px-4 md:px-8 py-20 grid lg:grid-cols-5 gap-12 items-start\"><div class=\"lg:col-span-2 space-y-4\"><div class=\"section-divider\"></div><h2 class=\"font-display text-3xl text-slate-800 tracking-wider mb-2\">Trial Info</h2><p class=\"text-slate-500 text-sm font-medium leading-relaxed mb-8\">Bring your university ID and wear appropriate sports attire. All positions are currently open for trials.</p><div class=\"space-y-3\"><div class=\"card p-4 flex gap-4 items-center bg-white border-slate-200\"><div class=\"w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center shrink-0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-5 h-5 text-brand-blue\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg></div><div><div class=\"text-[9px] font-bold text-slate-400 uppercase tracking-widest\">Time</div><div class=\"text-slate-800 text-sm font-bold\">5:30 PM – 7:00 PM</div></div></div><div class=\"card p-4 flex gap-4 items-center bg-white border-slate-200\"><div class=\"w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center shrink-0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin w-5 h-5 text-brand-blue\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg></div><div><div class=\"text-[9px] font-bold text-slate-400 uppercase tracking-widest\">Venue</div><div class=\"text-slate-800 text-sm font-bold\">Football Ground, Sanjivani</div></div></div><div class=\"card p-4 flex gap-4 items-center bg-white border-slate-200\"><div class=\"w-10 h-10 rounded-xl bg-blue-50 border border-blue-100 flex items-center justify-center shrink-0\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user w-5 h-5 text-brand-blue\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg></div><div><div class=\"text-[9px] font-bold text-slate-400 uppercase tracking-widest\">Open to</div><div class=\"text-slate-800 text-sm font-bold\">All enrolled students</div></div></div></div></div><div class=\"lg:col-span-3\"><form noValidate=\"\" class=\"card bg-white p-8 md:p-10 border-slate-200 shadow-soft-lg space-y-6\"><h3 class=\"font-display text-3xl text-brand-blue tracking-wider mb-2\">Application Form</h3><div class=\"space-y-2\"><label for=\"fullName\" class=\"flex items-center gap-1.5 text-[11px] font-bold text-slate-500 uppercase tracking-widest\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-user w-3.5 h-3.5 text-brand-blue\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\"></path><circle cx=\"12\" cy=\"7\" r=\"4\"></circle></svg> <!-- -->Full Name</label><input id=\"fullName\" type=\"text\" placeholder=\"As per university records\" class=\"w-